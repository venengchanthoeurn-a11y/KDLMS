# ================================================================
# includes/.htaccess — Protect includes directory from direct access
# KDLMS - Khmer Digital Library Management System
# ================================================================

# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Disable directory listing
Options -Indexes
