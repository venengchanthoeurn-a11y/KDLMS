{
  "version": 2,
  "builds": [
    {
      "src": "*.php",
      "use": "vercel-php@0.7.1",
      "config": {
        "includeFiles": ["includes/**", "kdlms.sqlite"]
      }
    },
    {
      "src": "admin/*.php",
      "use": "vercel-php@0.7.1",
      "config": {
        "includeFiles": ["includes/**", "kdlms.sqlite"]
      }
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "manifest.json",
      "use": "@vercel/static"
    },
    {
      "src": "sw.js",
      "use": "@vercel/static"
    },
    {
      "src": "offline.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/(includes|sql|scratch|uploads|\\.git|\\.vercel|\\.env|composer\\.json|package\\.json|package-lock\\.json|vercel\\.json|php\\.ini|README\\.md|kdlms\\.sqlite)(/.*)?$",
      "status": 403
    },
    {
      "src": "/sw\\.js",
      "dest": "/sw.js",
      "headers": {
        "Service-Worker-Allowed": "/",
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/manifest\\.json",
      "dest": "/manifest.json",
      "headers": {
        "Content-Type": "application/manifest+json",
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/uploads/$1"
    },
    {
      "src": "/offline\\.html",
      "dest": "/offline.html"
    },
    {
      "src": "/",
      "dest": "/index.php"
    }
  ]
}
