# ================================================================
# .htaccess — Root KDLMS Configuration
# KDLMS - Khmer Digital Library Management System
# Author: អេង ចាន់ធឿន (Eng Chanthoeun - Vthe)
# ================================================================

Options -Indexes
ServerSignature Off

# ----------------------------------------------------------------
# UTF-8 / Khmer Text Encoding — ការកំណត់ Encoding UTF-8
# ----------------------------------------------------------------
AddDefaultCharset UTF-8
AddCharset UTF-8 .php .html .htm .js .css .txt .xml .json

# Force PHP to use UTF-8
php_value default_charset "UTF-8"
php_value mbstring.internal_encoding "UTF-8"
php_value mbstring.func_overload "0"

# ----------------------------------------------------------------
# PHP includes protection — Block direct access to include files
# ----------------------------------------------------------------
<FilesMatch "^(db|auth|functions|header|footer|admin_header)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# ----------------------------------------------------------------
# Security Headers
# ----------------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # Ensure UTF-8 is declared on all text responses
    Header always set Content-Type "text/html; charset=UTF-8" "expr=%{CONTENT_TYPE} == 'text/html'"
</IfModule>

# ----------------------------------------------------------------
# Protect sensitive files, databases, logs, and .htaccess itself
# ----------------------------------------------------------------
<FilesMatch "^(kdlms\.sqlite|php\.ini|vercel\.json|composer\.json|package\.json|package-lock\.json|README\.md|\.env.*|\.git.*)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

<FilesMatch "\.(sqlite|sqlite3|db|sql|log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

<Files ".htaccess">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>

# ----------------------------------------------------------------
# Compression — ការបង្ហាប់
# ----------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json text/plain
</IfModule>

# ----------------------------------------------------------------
# Browser Caching — Cache Assets
# ----------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
